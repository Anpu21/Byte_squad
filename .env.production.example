# LedgerPro backend — PRODUCTION environment template (DigitalOcean droplet).
#
# Copy to ~/ledgerpro/.env ON THE DROPLET (chmod 600) and fill real values.
# NEVER commit the real .env. docker-compose.prod.yml reads this file.
#
# NOTE: production requires the RS256 keys introduced by the auth migration
# (feat/auth-rs256-jwks-refresh). Deploy this pipeline only AFTER that PR is
# merged to main, otherwise the image still expects the old JWT_SECRET.

NODE_ENV=production
PORT=3000

# ── Image (optional override; defaults to ghcr.io/anpu21/ledgerpro-backend) ──
# BACKEND_IMAGE=ghcr.io/anpu21/ledgerpro-backend
# IMAGE_TAG is set by the deploy workflow (sha-XXXXXXX); defaults to "latest".

# ── External Postgres (managed / existing) ──
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
DB_SSL=true        # required for managed Postgres (TLS)
DB_SYNC=false      # MUST be false in production (env.validation enforces)
DB_LOGGING=false

# ── Auth — RS256 (from the Phase-0 auth migration) ──
# Generate once:
#   openssl genpkey -algorithm RSA -pkcs8 -out jwtRS256.key -pkeyopt rsa_keygen_bits:2048
#   base64 -w0 jwtRS256.key      # paste the single-line output below
# JWT_PRIVATE_KEY accepts base64 OR raw PEM; the public key is derived if omitted.
JWT_PRIVATE_KEY=
JWT_KEY_ID=kid-2026-06
# Optional (sensible defaults exist):
# JWT_PUBLIC_KEY=
# JWT_ISSUER=ledgerpro-backend
# JWT_AUDIENCE=ledgerpro-api
# JWT_EXPIRES_IN=1d
# JWT_REFRESH_EXPIRES_IN=30d

# ── App ──
CORS_ORIGIN=https://app.ledgerpro.shop
BACKEND_PUBLIC_URL=https://api.ledgerpro.shop

# ── Email (copy current Fly secret values) ──
RESEND_API_KEY=
MAIL_FROM=LedgerPro <noreply@ledgerpro.shop>
TEMP_PASSWORD_EXPIRES_HOURS=48
# If using SMTP/Nodemailer instead of Resend:
# MAIL_HOST=
# MAIL_PORT=
# MAIL_USERNAME=
# MAIL_PASSWORD=

# ── Cloudinary (image uploads) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── PayHere (checkout) ──
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_CHECKOUT_URL=https://sandbox.payhere.lk/pay/checkout
PAYHERE_NOTIFY_URL=
PAYHERE_RETURN_URL=
PAYHERE_CANCEL_URL=
