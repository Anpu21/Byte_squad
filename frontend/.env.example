# Frontend env for HOST dev only (`pnpm dev` inside ./frontend). Copy to
# frontend/.env. When you run the whole stack with `docker compose up`, these
# values come from the root .env / docker-compose.yml and this file is ignored.
#
# Only VITE_-prefixed vars are exposed to the client bundle.

# Backend REST API (NestJS). Matches the backend host port (root .env PORT, 4000 here).
VITE_API_URL=http://localhost:4000/api/v1

# Standalone realtime service — chat + notifications WebSockets and the /chat REST
# API. This is a SEPARATE origin from the API above; if you point it at the api URL
# the chat 404s with "Couldn't open the group chat." Matches the realtime host port
# (root .env REALTIME_PORT, 4001 here). In production this is https://realtime.<domain>.
VITE_SOCKET_URL=http://localhost:4001

# Optional — only if the app uses Supabase directly from the client.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
