# ╔═══════════════════════════════════════════════════════════╗
# ║  LedgerPro — Development Environment Variables            ║
# ║  Usage: Copy this file to .env.development                ║
# ║    cp .env.development.example .env.development            ║
# ╚═══════════════════════════════════════════════════════════╝
# ── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
BACKEND_API_URL=http://backend:3000

# ── Database (Local Docker PostgreSQL) ───────────────────
# These must match the postgres service in docker-compose.yml
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=ledgerpro
DB_PASSWORD=ledgerpro_dev
DB_NAME=ledgerpro_dev
DB_SYNC=true
DB_LOGGING=true

# ── Auth / JWT ───────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=86400

# ── Default Admin Seed ───────────────────────────────────
# These credentials are used to create the first admin user on startup
SEED_ADMIN_EMAIL=admin@ledgerpro.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_FIRST_NAME=System
SEED_ADMIN_LAST_NAME=Admin
SEED_ADMIN_BRANCH_NAME=Main Branch
SEED_ADMIN_BRANCH_ADDRESS=Head Office
SEED_ADMIN_BRANCH_PHONE=+94000000000

# ── Email / SMTP ───────────────────────────────────────
# For Gmail: enable 2FA and create an App Password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
TEMP_PASSWORD_EXPIRES_HOURS=24

# ── Supabase (Optional — only if using Supabase services) ─
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Frontend (VITE_ prefix required for client-side access) ─
VITE_API_URL=http://localhost:3000/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Cloudinary (Optional — falls back to base64 in DB if any are unset) ─
# Get these from your Cloudinary dashboard: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
