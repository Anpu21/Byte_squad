# ╔═══════════════════════════════════════════════════════════╗
# ║  LedgerPro — Development Environment Variables            ║
# ║  Usage: Copy this file to .env.development                ║
# ║    cp .env.development.example .env.development            ║
# ╚═══════════════════════════════════════════════════════════╝
# ── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
BACKEND_API_URL=http://backend:3000

# ── Database (Local Docker PostgreSQL) ───────────────────
# These must match the postgres service in docker-compose.yml
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=ledgerpro
DB_PASSWORD=ledgerpro_dev
DB_NAME=ledgerpro_dev
DB_SYNC=true
DB_LOGGING=true

# ── Auth / JWT ───────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=86400

# ── Default Admin Seed ───────────────────────────────────
# These credentials are used to create the first admin user on startup
SEED_ADMIN_EMAIL=admin@ledgerpro.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_FIRST_NAME=System
SEED_ADMIN_LAST_NAME=Admin
SEED_ADMIN_BRANCH_NAME=Main Branch
SEED_ADMIN_BRANCH_ADDRESS=Head Office
SEED_ADMIN_BRANCH_PHONE=+94000000000

# ── Email / SMTP ───────────────────────────────────────
# For Gmail: enable 2FA and create an App Password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
TEMP_PASSWORD_EXPIRES_HOURS=24

# ── Supabase (Optional — only if using Supabase services) ─
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Frontend (VITE_ prefix required for client-side access) ─
VITE_API_URL=http://localhost:3000/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Cloudinary (Optional — falls back to base64 in DB if any are unset) ─
# Get these from your Cloudinary dashboard: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── PayHere (Sandbox-by-default, required for online customer-order payments) ─
# Get these from https://sandbox.payhere.lk → Settings → Domains & Credentials.
# Without PAYHERE_MERCHANT_ID + PAYHERE_MERCHANT_SECRET the online-checkout
# flow throws 503; the manual "pay at pickup" flow still works.
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
# Public URL of the backend that PayHere can POST notify callbacks to. For
# local dev, expose port 3000 via ngrok / cloudflared and paste that URL here.
# Defaults to http://localhost:3000 — fine for local tests of the redirect
# page, but PayHere itself cannot reach localhost so notify will be skipped.
BACKEND_PUBLIC_URL=http://localhost:3000
# Optional overrides — leave blank to derive from BACKEND_PUBLIC_URL/CORS_ORIGIN.
PAYHERE_CHECKOUT_URL=https://sandbox.payhere.lk/pay/checkout
PAYHERE_NOTIFY_URL=
PAYHERE_RETURN_URL=
PAYHERE_CANCEL_URL=
